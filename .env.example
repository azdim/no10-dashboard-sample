NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=no10assesment
# Endpoint ONLY — do not append /bucket. EU jurisdiction buckets use .eu. in the host:
#   https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
# Non-EU:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
DATA_SOURCE=local     # local | r2 — use r2 on Vercel/production
DATA_ROOT=./data      # used when DATA_SOURCE=local (from repo root); portal uses ../data
# REPO_ROOT=           # optional absolute override if config/ is not found via cwd
AWS_REGION=auto       # required by S3 SDK for R2; use auto
